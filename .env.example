# ========================================
# 增长组业务管理系统 - 环境变量配置
# ========================================
# 复制此文件为 .env 并填写实际值
# 生产环境必须修改所有标记为 [REQUIRED] 的变量

# ==================== 数据库 ====================
# 数据库类型：sqlite（开发） / postgres（生产）
DB_DIALECT=sqlite

# PostgreSQL 配置（生产环境使用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=growth_system
DB_USER=growth
DB_PASSWORD=[REQUIRED_CHANGE_ME]

# ==================== 安全 ====================
# JWT 密钥 [REQUIRED] - 生产环境必须使用强随机字符串
# 可用命令生成：openssl rand -hex 32
# ⚠️ 生产环境未设置或使用默认值将导致启动失败
JWT_SECRET=[REQUIRED_CHANGE_ME_TO_STRONG_RANDOM]

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 是否开放公开注册（默认关闭）
# 设置为 true 允许任何人注册（注册后状态为 pending，需管理员审核）
ENABLE_PUBLIC_REGISTER=false

# ==================== 环境 ====================
NODE_ENV=development

# ==================== 服务端口 ====================
PORT=3001
