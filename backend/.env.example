# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=growth_system
DB_USER=growth
# ⚠️ 生产环境必须替换为强密码
DB_PASSWORD=请替换为强密码

# JWT 配置
# ⚠️ 生产环境必须修改为强随机密钥，否则启动失败
# 生成命令：openssl rand -hex 32
JWT_SECRET=请使用_openssl_rand_hex_32_生成
JWT_EXPIRES_IN=7d

# Docker Compose 环境变量（与上方保持一致）
POSTGRES_USER=growth
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=growth_system

# 环境
NODE_ENV=development
PORT=3001

# 注册控制（默认关闭公开注册）
ENABLE_PUBLIC_REGISTER=false

# Seed 账号控制
# 默认随机化初始密码并强制首次改密。仅本地临时调试时才设置 ALLOW_INSECURE_DEFAULT_SEED=true。
DEFAULT_SEED_PASSWORD=
ALLOW_INSECURE_DEFAULT_SEED=false

# AI 助手配置
AI_LLM_PROVIDER=deepseek
# ⚠️ 不要在此处填写真实 API Key，使用环境变量或密钥管理工具
AI_LLM_API_KEY=
AI_LLM_MODEL=deepseek-chat
AI_LLM_BASE_URL=https://api.deepseek.com
# 推理型模型（如 deepseek-v4-flash）会先消耗 reasoning token，需给足预算，否则结构化输出被截断为空
AI_LLM_MAX_TOKENS=2048
AI_LLM_TEMPERATURE=0.7

# AI 旁路增强开关（默认开启；如需灰度/回滚，显式设置为 false）
AI_SIDE_CAR_ENABLED=true
AI_PERSONAL_DIGEST_ENABLED=true
AI_WEEKLY_OPERATING_BRIEF_ENABLED=true
AI_EMAIL_ENABLED=false
